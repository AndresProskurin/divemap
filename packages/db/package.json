{
  "name": "@divemap/db",
  "version": "0.1.0",
  "private": true,
  "sideEffects": false,
  "exports": {
    ".":        "./src/index.ts",
    "./types":  "./src/types.ts",
    "./client": "./src/client.ts",
    "./server": "./src/server.ts",
    "./hooks/useAuth": "./src/hooks/useAuth.ts"
  },
  "scripts": {
    "db:push": "supabase db push",
    "db:types": "supabase gen types typescript --project-id \"$SUPABASE_PROJECT_ID\" --schema public > src/types.ts",
    "lint": "tsc --noEmit",
    "clean": "rm -rf .turbo node_modules"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.5"
  },
  "peerDependencies": {
    "react": "^18.3.1 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.19.9",
    "@types/react": "^18.3.12",
    "supabase": "^2.54.11",
    "typescript": "^5.9.3"
  }
}
