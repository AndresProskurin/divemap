# Isolated node_modules (pnpm default). Required: apps/web pins React 18
# (Next 14) while apps/mobile pins React 19 (Expo 57). Hoisting would collapse
# them into one root copy and break whichever app loses.
node-linker=isolated

# Metro/RN and Next both need their peers resolvable without manual wiring.
auto-install-peers=true
strict-peer-dependencies=false
